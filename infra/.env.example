# ==============================================================================
# TheMatrix — Environment Variables
# Copy to .env and fill in real values for local development only.
# NEVER commit .env to version control.
# NEVER embed secrets in mobile app.
# Use a secrets manager in production.
# ==============================================================================

# --- Application ---
APP_ENV=development          # development | staging | production
APP_NAME=TheMatrix
APP_VERSION=0.1.0
DEBUG=true                   # MUST be false in production
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=TheMatrix
POSTGRES_USER=TheMatrix_user
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql+asyncpg://TheMatrix_user:CHANGE_ME_POSTGRES_PASSWORD@db:5432/TheMatrix

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Password Hashing ---
# Argon2id is the default — do not change without understanding the security implications
PASSWORD_HASH_ALGORITHM=argon2id

# --- Rate Limiting ---
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=60
RATE_LIMIT_ADVISOR_PER_MINUTE=10
RATE_LIMIT_SCREEN_PER_MINUTE=5

# --- LLM Provider ---
# Set USE_MOCK_LLM=true for local dev (no real API calls)
USE_MOCK_LLM=true
LLM_PROVIDER=openai             # mock | openai | anthropic | azure_openai
OPENAI_API_KEY=CHANGE_ME_YOUR_OPENAI_KEY
ANTHROPIC_API_KEY=CHANGE_ME_IF_USING_ANTHROPIC
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3

# --- Embedding Provider ---
USE_MOCK_EMBEDDING=true
EMBEDDING_PROVIDER=mock       # mock | openai | local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# --- Search Provider ---
USE_MOCK_SEARCH=true
SEARCH_PROVIDER=mock          # mock | brave | google | serper

# --- OCR Provider ---
USE_MOCK_OCR=true
OCR_PROVIDER=mock             # mock | google_vision | aws_textract | local_tesseract

# --- Speech Provider ---
USE_MOCK_SPEECH=true
SPEECH_PROVIDER=mock          # mock | whisper | google | azure

# --- Social Media (Facebook Mind) ---
# Create your app at developers.facebook.com → My Apps (Consumer type)
# Add "Facebook Login" product → set Valid OAuth Redirect URIs to your backend URL
# Required permissions: public_profile, email, pages_show_list,
#   pages_read_engagement, pages_manage_posts, user_posts
FACEBOOK_APP_ID=                # App ID from developers.facebook.com → Settings → Basic
FACEBOOK_APP_SECRET=            # App Secret from developers.facebook.com → Settings → Basic
API_BASE_URL=http://localhost:8000   # Your deployed backend URL (for OAuth redirect URI)

# --- Encryption ---
# In production, use KMS. For dev, use a local key (NOT for real data)
FIELD_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY_FOR_DEV_ONLY
USE_KMS=false
KMS_KEY_ID=CHANGE_ME_IF_USING_KMS

# --- Core Mind Blueprint ---
# Creator authority signing key placeholder (production: HSM/KMS)
BLUEPRINT_SIGNING_KEY=CHANGE_ME_BLUEPRINT_SIGNING_KEY
BLUEPRINT_SIGNING_ALGORITHM=RS256  # placeholder — use real key pair in prod

# --- Admin ---
# Initial admin seed (development only) — remove in production
DEV_ADMIN_EMAIL=admin@TheMatrix.local
DEV_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD_DEV_ONLY

# --- Observability ---
LOG_LEVEL=INFO
ENABLE_OPENTELEMETRY=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=                   # leave blank to disable

# --- Storage ---
# For screenshots (default: local for dev, object storage for prod)
STORAGE_BACKEND=local         # local | s3 | gcs
STORAGE_LOCAL_PATH=./data/uploads
S3_BUCKET=CHANGE_ME_S3_BUCKET
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# --- Privacy defaults ---
DEFAULT_ALLOW_MEMORY=false
DEFAULT_ALLOW_SCREEN_GUARDIAN=false
DEFAULT_ALLOW_VOICE_PROCESSING=false
DEFAULT_ALLOW_ANONYMIZED_TRAINING=false
DEFAULT_ALLOW_SENSITIVE_SESSION_STORAGE=false

# --- TLS (production) ---
# TLS_CERT_PATH=/etc/ssl/certs/TheMatrix.crt
# TLS_KEY_PATH=/etc/ssl/private/TheMatrix.key
